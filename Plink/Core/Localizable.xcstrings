        "en" : { "stringUnit" : { "state" : "translated", "value" : "Press your desired key combination, e.g. ⌃Space or ⌥N." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Gewünschte Tastenkombination drücken, z.B. ⌃Leertaste oder ⌥N." } }
      }
    },

    "settings.shortcut.step3" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "The shortcut is saved immediately." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Das Kürzel wird sofort gespeichert." } }
      }
    },

    "settings.shortcut.warning" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Avoid ⌘Space — it is reserved by Spotlight." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "⌘Leertaste vermeiden – sie ist für Spotlight reserviert." } }
      }
    },

    "settings.reset.title" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Reset" } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Zurücksetzen" } }
      }
    },

    "settings.reset.desc" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Delete all tasks and groups and start fresh. This cannot be undone." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Alle Aufgaben und Gruppen löschen und neu beginnen. Dies kann nicht rückgängig gemacht werden." } }
      }
    },

    "settings.reset.permanent" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Everything will be permanently deleted." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Alles wird endgültig gelöscht." } }
      }
    },

    "settings.reset.button" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Reset Plink" } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Plink zurücksetzen" } }
      }
    },

    "settings.reset.confirm.title" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Reset Plink?" } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Plink zurücksetzen?" } }
      }
    },

    "settings.reset.summary" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "%d tasks · %d groups" } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "%d Aufgaben · %d Gruppen" } }
      }
    },
    "settings.reset.confirm.message" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "This will permanently delete all %d tasks and %d groups. There is no way to undo this." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Alle %d Aufgaben und %d Gruppen werden endgültig gelöscht. Dies kann nicht rückgängig gemacht werden." } }
      }
    },
    "settings.reset.confirm.button" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Delete Everything" } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Alles löschen" } }
      }
    },

    "settings.language.title" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Language" } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Sprache" } }
      }
    },

    "settings.language.desc" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Choose the language for Plink. Defaults to your macOS language." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Sprache für Plink wählen. Standard ist die macOS-Systemsprache." } }
      }
    },

    "settings.language.en" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "English" } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Englisch" } }
      }
    },

    "settings.language.de" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Deutsch" } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Deutsch" } }
      }
    },

    "settings.language.restart" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Restart Plink to apply the language change." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Plink neu starten, um die Sprache zu übernehmen." } }
      }
    },

    "settings.language.restart.button" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Restart Now" } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Jetzt neu starten" } }
      }
    },

    "settings.language.spanish.soon" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Spanish — coming later this year" } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Spanisch — kommt später dieses Jahr" } }
      }
    },

    "settings.language.spanish.badge" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Coming Soon" } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Demnächst" } }
      }
    },

    "onboarding.welcome.title" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Welcome to Plink" } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Willkommen bei Plink" } }
      }
    },

    "onboarding.welcome.subtitle" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "The fastest way to capture tasks on your Mac." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Die schnellste Art, Aufgaben auf dem Mac festzuhalten." } }
      }
    },

    "onboarding.welcome.body" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Plink lives in your menu bar and is always one shortcut away — no matter what app you're in." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Plink lebt in deiner Menüleiste und ist immer nur einen Tastendruck entfernt – egal welche App du gerade verwendest." } }
      }
    },

    "onboarding.quickadd.title" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Quick Add" } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Schnelleingabe" } }
      }
    },

    "onboarding.quickadd.subtitle" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Capture anything in under a second." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Alles in unter einer Sekunde erfassen." } }
      }
    },

    "onboarding.quickadd.body" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Press ⌥Space from any app to open the Quick Add panel. Type your task and hit Return. Done.\n\nYou can customize the shortcut any time in Settings." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "⌥Leertaste aus jeder App drücken, um das Schnelleingabe-Panel zu öffnen. Aufgabe eintippen und Return drücken. Fertig.\n\nDas Tastenkürzel kann jederzeit in den Einstellungen angepasst werden." } }
      }
    },

    "onboarding.smart.title" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Smart Input" } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Smarte Eingabe" } }
      }
    },

    "onboarding.smart.subtitle" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Just describe what you need to do." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Einfach beschreiben, was zu tun ist." } }
      }
    },

    "onboarding.smart.body" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Enable Smart Input and Plink will automatically extract the title, due date, and priority from natural language.\n\n\"Call John tomorrow, urgent\" → due tomorrow · high priority" } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Smarte Eingabe aktivieren und Plink erkennt automatisch Titel, Datum und Priorität aus natürlicher Sprache.\n\n\"Morgen John anrufen, dringend\" → fällig morgen · hohe Priorität" } }
      }
    },

    "onboarding.groups.title" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Groups" } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Gruppen" } }
      }
    },

    "onboarding.groups.subtitle" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Keep your tasks organised." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Aufgaben strukturiert halten." } }
      }
    },

    "onboarding.groups.body" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Create groups for Work, Personal, or any project. Filter the dashboard with a single click.\n\nTasks without a group live in Unassigned — always visible, never lost." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Gruppen für Arbeit, Privates oder beliebige Projekte erstellen. Dashboard mit einem Klick filtern.\n\nAufgaben ohne Gruppe landen in \"Nicht zugeordnet\" – immer sichtbar, nie verloren." } }
      }
    },

    "onboarding.accent.title" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Make it yours" } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Mach es zu deinem" } }
      }
    },

    "onboarding.accent.subtitle" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Pick an accent color to personalise Plink." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Eine Akzentfarbe wählen, um Plink zu personalisieren." } }
      }
    },

    "onboarding.button.continue" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Continue" } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Weiter" } }
      }
    },

    "onboarding.button.getStarted" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Get Started" } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Loslegen" } }
      }
    },

    "onboarding.button.skip" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Skip" } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Überspringen" } }
      }
    },

    "help.dashboard.title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Dashboard" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Übersicht" } } } },
    "help.dashboard.s1.heading" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Overview" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Übersicht" } } } },
    "help.dashboard.s1.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The dashboard shows all your open tasks organised into sections: Overdue, Today, Tomorrow, Upcoming, Someday, and Recently Completed.\n\nOverdue tasks are highlighted in red to draw your attention. Recently Completed tasks disappear from the dashboard after 30 minutes and move to Trash." } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Die Übersicht zeigt alle offenen Aufgaben in Abschnitten: Überfällig, Heute, Morgen, Demnächst, Irgendwann und Kürzlich erledigt.\n\nÜberfällige Aufgaben sind rot hervorgehoben. Kürzlich erledigte Aufgaben verschwinden nach 30 Minuten aus der Übersicht und werden in den Papierkorb verschoben." } } } },
    "help.dashboard.s2.heading" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Completing a task" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Aufgabe erledigen" } } } },
    "help.dashboard.s2.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Hover over any task row — a teal ✓ button appears on the right. Click it to mark the task as complete. You can also right-click a row and choose Mark Complete." } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Über eine Aufgabenzeile hovern — rechts erscheint ein türkiser ✓-Button. Klicken, um die Aufgabe als erledigt zu markieren. Alternativ Rechtsklick und \"Als erledigt markieren\" wählen." } } } },
    "help.dashboard.s2.tip" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Completed tasks stay visible for 30 minutes so you can undo by mistake." } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Erledigte Aufgaben bleiben 30 Minuten sichtbar, damit versehentliche Aktionen rückgängig gemacht werden können." } } } },
    "help.dashboard.s3.heading" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Editing a task" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Aufgabe bearbeiten" } } } },
    "help.dashboard.s3.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Click anywhere on a task row (except the complete button) to open the detail panel. Here you can edit the title, description, due date, priority and group.\n\nChanges are saved automatically when you close the panel. Press Esc or click the × button to discard." } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Auf eine Aufgabenzeile klicken (nicht auf den Erledigt-Button), um das Detailfeld zu öffnen. Dort können Titel, Beschreibung, Datum, Priorität und Gruppe bearbeitet werden.\n\nÄnderungen werden beim Schließen automatisch gespeichert. Esc oder × drücken, um zu verwerfen." } } } },
    "help.dashboard.s4.heading" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Deleting a task" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Aufgabe löschen" } } } },
    "help.dashboard.s4.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Right-click a task row and choose Delete. The task moves to Trash and can be restored within 6 months." } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Rechtsklick auf eine Aufgabenzeile und \"Löschen\" wählen. Die Aufgabe wird in den Papierkorb verschoben und kann innerhalb von 6 Monaten wiederhergestellt werden." } } } },

    "help.quickadd.title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Quick Add" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Schnelleingabe" } } } },
    "help.quickadd.s1.heading" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Global shortcut" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Globales Tastenkürzel" } } } },
    "help.quickadd.s1.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Press ⌥Space (Option + Space) from any app — even when Plink is in the background — to open the Quick Add panel. Plink never steals focus from your current window." } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "⌥Leertaste (Option + Leertaste) aus jeder App drücken — auch wenn Plink im Hintergrund ist — um das Schnelleingabe-Panel zu öffnen. Plink übernimmt niemals den Fokus vom aktuellen Fenster." } } } },
    "help.quickadd.s1.tip" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "You can change this shortcut in Settings → Shortcut." } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Dieses Kürzel kann unter Einstellungen → Tastenkürzel geändert werden." } } } },
    "help.quickadd.s2.heading" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Adding a task" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Aufgabe hinzufügen" } } } },
    "help.quickadd.s2.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Type your task title and press Return or click the → button. The panel closes automatically after adding." } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Aufgabentitel eingeben und Return drücken oder den →-Button klicken. Das Panel schließt sich nach dem Hinzufügen automatisch." } } } },
    "help.quickadd.s3.heading" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Due date" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Fälligkeitsdatum" } } } },
    "help.quickadd.s3.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Use the Today and Tomorrow chips for quick date assignment. Click the calendar chip to pick any future date from the mini calendar." } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Die Chips \"Heute\" und \"Morgen\" für schnelle Datumszuweisung verwenden. Auf den Kalender-Chip klicken, um ein beliebiges Datum aus dem Mini-Kalender zu wählen." } } } },
    "help.quickadd.s4.heading" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Priority" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Priorität" } } } },
    "help.quickadd.s4.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Click the 🚩 flag menu to set a priority: Low, Medium or High. Priority is shown as a coloured dot on the task row." } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Auf das 🚩-Flag-Menü klicken, um eine Priorität zu setzen: Niedrig, Mittel oder Hoch. Die Priorität wird als farbiger Punkt in der Aufgabenzeile angezeigt." } } } },
    "help.quickadd.s5.heading" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Group" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Gruppe" } } } },
    "help.quickadd.s5.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "If you have created groups, a folder menu appears. Select a group to assign the task to it, or leave it unassigned." } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Wenn Gruppen erstellt wurden, erscheint ein Ordner-Menü. Eine Gruppe auswählen, um die Aufgabe zuzuweisen, oder nicht zugeordnet lassen." } } } },
    "help.quickadd.s6.heading" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Closing the panel" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Panel schließen" } } } },
    "help.quickadd.s6.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Press Esc, press Return on an empty field, or click anywhere outside the panel to close it." } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Esc drücken, Return in einem leeren Feld drücken oder außerhalb des Panels klicken, um es zu schließen." } } } },

    "help.smart.title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Smart Input" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Smarte Eingabe" } } } },
    "help.smart.s1.heading" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "What is Smart Input?" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Was ist die smarte Eingabe?" } } } },
    "help.smart.s1.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Smart Input lets you describe a task in plain, natural language. Plink automatically extracts the title, due date and priority from your text — no need to set them manually." } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Die smarte Eingabe ermöglicht es, Aufgaben in natürlicher Sprache zu beschreiben. Plink erkennt automatisch Titel, Datum und Priorität — ohne manuelle Eingabe." } } } },
    "help.smart.s2.heading" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Enabling Smart Input" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Smarte Eingabe aktivieren" } } } },
    "help.smart.s2.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Go to Settings → Smart Input and turn on the toggle. A ✦ Smart button will appear in the Quick Add panel and the New Task sheet." } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Unter Einstellungen → Smarte Eingabe den Schalter aktivieren. Ein ✦-Smart-Button erscheint dann in der Schnelleingabe und im Neue-Aufgabe-Dialog." } } } },
    "help.smart.s3.heading" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Example inputs" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Beispiele" } } } },
    "help.smart.s3.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "• \"Call John tomorrow, urgent\" → Title: Call John · Due: Tomorrow · Priority: High\n• \"Buy groceries in two weeks\" → Title: Buy groceries · Due: in 14 days\n• \"Wednesday, prepare the presentation\" → Title: Prepare the presentation · Due: next Wednesday\n• \"Team sync next Monday, important\" → Title: Team sync · Due: next Monday · Priority: Medium" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "• \"Morgen John anrufen, dringend\" → Titel: John anrufen · Datum: Morgen · Priorität: Hoch\n• \"Lebensmittel in zwei Wochen kaufen\" → Titel: Lebensmittel kaufen · Datum: in 14 Tagen\n• \"Mittwoch, Präsentation vorbereiten\" → Titel: Präsentation vorbereiten · Datum: nächsten Mittwoch\n• \"Team-Meeting nächsten Montag, wichtig\" → Titel: Team-Meeting · Datum: nächsten Montag · Priorität: Mittel" } } } },
    "help.smart.s4.heading" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Supported date expressions" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Unterstützte Datumsangaben" } } } },
    "help.smart.s4.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Today · Tomorrow · Next/this [weekday] · [Weekday] in X weeks · In X days/weeks/months · Absolute dates (e.g. January 15)" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Heute · Morgen · Nächsten/diesen [Wochentag] · [Wochentag] in X Wochen · In X Tagen/Wochen/Monaten · Absolute Daten (z.B. 15. Januar)" } } } },
    "help.smart.s5.heading" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Supported priority words" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Unterstützte Prioritätswörter" } } } },
    "help.smart.s5.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "High: urgent, asap, critical, super urgent, immediately\nMedium: important, soon\nLow: whenever, someday, no rush" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Hoch: dringend, sofort, kritisch, super dringend, sofort\nMittel: wichtig, bald\nNiedrig: irgendwann, kein Stress" } } } },
    "help.smart.s5.tip" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "German keywords are also supported: dringend, sofort, wichtig, bald, irgendwann." } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Deutsche Schlüsselwörter werden unterstützt: dringend, sofort, wichtig, bald, irgendwann." } } } },
    "help.smart.s6.heading" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Engine" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Engine" } } } },
    "help.smart.s6.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "On macOS 26+ with Apple Intelligence enabled, Smart Input uses the on-device language model for best results. On earlier systems it uses Apple's Natural Language framework — slightly less precise but fully private." } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Auf macOS 26+ mit aktivierter Apple Intelligence verwendet die smarte Eingabe das lokale Sprachmodell für beste Ergebnisse. Auf älteren Systemen wird Apples Natural-Language-Framework verwendet — etwas weniger präzise, aber vollständig privat." } } } },
    "help.smart.s6.tip" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "All processing is on-device. Nothing is sent to any server." } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Alle Verarbeitung erfolgt auf dem Gerät. Es werden keine Daten an Server gesendet." } } } },

    "help.groups.title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Groups" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Gruppen" } } } },
    "help.groups.s1.heading" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Creating a group" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Gruppe erstellen" } } } },
    "help.groups.s1.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Click + New Group in the sidebar and type a name, then press Return. Groups appear in the sidebar below Unassigned." } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "In der Seitenleiste auf + Neue Gruppe klicken, einen Namen eingeben und Return drücken. Gruppen erscheinen in der Seitenleiste unterhalb von \"Nicht zugeordnet\"." } } } },
    "help.groups.s2.heading" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Unassigned" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Nicht zugeordnet" } } } },
    "help.groups.s2.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Unassigned is a permanent, built-in group that automatically collects all tasks without a group. It cannot be deleted." } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "\"Nicht zugeordnet\" ist eine permanente, eingebaute Gruppe, die automatisch alle Aufgaben ohne Gruppe sammelt. Sie kann nicht gelöscht werden." } } } },
    "help.groups.s3.heading" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Task counts" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Aufgabenzähler" } } } },
    "help.groups.s3.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Each group shows two badges:\n• A neutral badge — total open tasks\n• A red badge — overdue tasks (replaces the neutral badge when present)" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Jede Gruppe zeigt zwei Badges:\n• Ein neutrales Badge — Gesamtzahl offener Aufgaben\n• Ein rotes Badge — überfällige Aufgaben (ersetzt das neutrale Badge, wenn vorhanden)" } } } },
    "help.groups.s4.heading" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Deleting a group" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Gruppe löschen" } } } },
    "help.groups.s4.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Right-click a group in the sidebar and choose Delete. A confirmation dialog gives you two options:" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Rechtsklick auf eine Gruppe in der Seitenleiste und \"Löschen\" wählen. Ein Bestätigungsdialog bietet zwei Optionen:" } } } },
    "help.groups.s4.tip" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "\"Delete Group and All Tasks\" → tasks move to Trash.\n\"Delete Group, Keep Tasks\" → tasks move to Unassigned." } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "\"Gruppe und alle Aufgaben löschen\" → Aufgaben werden in den Papierkorb verschoben.\n\"Gruppe löschen, Aufgaben behalten\" → Aufgaben werden nach \"Nicht zugeordnet\" verschoben." } } } },
    "help.groups.s5.heading" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Filtering by group" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Nach Gruppe filtern" } } } },
    "help.groups.s5.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Click any group in the sidebar to filter the dashboard to only that group's tasks. Click All Tasks to return to the full view." } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Auf eine Gruppe in der Seitenleiste klicken, um die Übersicht auf die Aufgaben dieser Gruppe zu filtern. Auf \"Alle Aufgaben\" klicken, um zur vollständigen Ansicht zurückzukehren." } } } },

    "help.search.title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Search" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Suche" } } } },
    "help.search.s1.heading" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Finding tasks" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Aufgaben finden" } } } },
    "help.search.s1.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Click the search bar in the toolbar (or press ⌘F) and start typing. Plink searches both the title and description of every task." } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "In der Symbolleiste auf die Suchleiste klicken (oder ⌘F drücken) und zu tippen beginnen. Plink durchsucht sowohl Titel als auch Beschreibung jeder Aufgabe." } } } },
    "help.search.s2.heading" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Completed tasks" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Erledigte Aufgaben" } } } },
    "help.search.s2.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "When a search query is active, completed tasks are also included in the results under a Completed section — not just recently completed ones." } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Wenn eine Suche aktiv ist, werden auch erledigte Aufgaben in den Ergebnissen unter einem \"Erledigt\"-Abschnitt angezeigt — nicht nur kürzlich erledigte." } } } },
    "help.search.s2.tip" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "This lets you find any task you have ever added, even if it was completed months ago." } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "So können alle jemals hinzugefügten Aufgaben gefunden werden, auch wenn sie vor Monaten erledigt wurden." } } } },
    "help.search.s3.heading" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Combining with groups" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Mit Gruppen kombinieren" } } } },
    "help.search.s3.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Search respects the current group filter. Select a group first and then search to find tasks only within that group." } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Die Suche berücksichtigt den aktuellen Gruppenfilter. Zuerst eine Gruppe auswählen und dann suchen, um nur Aufgaben dieser Gruppe zu finden." } } } },

    "help.trash.title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Trash" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Papierkorb" } } } },
    "help.trash.s1.heading" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "What appears in Trash" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Was im Papierkorb erscheint" } } } },
    "help.trash.s1.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Trash contains two kinds of items:\n• Deleted tasks — manually deleted from the dashboard or when a group was deleted\n• Completed tasks — moved here after the 30-minute visibility window" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Der Papierkorb enthält zwei Arten von Einträgen:\n• Gelöschte Aufgaben — manuell gelöscht oder beim Löschen einer Gruppe\n• Erledigte Aufgaben — nach dem 30-Minuten-Sichtbarkeitsfenster hierher verschoben" } } } },
    "help.trash.s2.heading" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Restoring a task" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Aufgabe wiederherstellen" } } } },
    "help.trash.s2.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Hover over a task in Trash and click Restore, or right-click and choose Restore. The task returns to the dashboard as an open task." } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Über eine Aufgabe im Papierkorb hovern und auf \"Wiederherstellen\" klicken, oder Rechtsklick und \"Wiederherstellen\" wählen. Die Aufgabe kehrt als offene Aufgabe in die Übersicht zurück." } } } },
    "help.trash.s3.heading" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Permanent deletion" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Endgültig löschen" } } } },
    "help.trash.s3.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Hover over a task and click Delete, or use the Clear button next to each section header to remove all items in that section at once.\n\nThe Empty Trash button in the toolbar permanently deletes everything in one action." } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Über eine Aufgabe hovern und auf \"Löschen\" klicken, oder den \"Leeren\"-Button neben jedem Abschnitt-Header verwenden, um alle Einträge auf einmal zu entfernen.\n\nDer \"Papierkorb leeren\"-Button in der Symbolleiste löscht alles auf einmal endgültig." } } } },
    "help.trash.s3.warning" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Permanent deletion cannot be undone." } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Endgültiges Löschen kann nicht rückgängig gemacht werden." } } } },
    "help.trash.s4.heading" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Automatic cleanup" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Automatische Bereinigung" } } } },
    "help.trash.s4.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Items in Trash are automatically and permanently deleted after 6 months. There is no manual action required." } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Einträge im Papierkorb werden nach 6 Monaten automatisch und endgültig gelöscht. Es ist keine manuelle Aktion erforderlich." } } } },

    "help.settings.title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Settings" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Einstellungen" } } } },
    "help.settings.s1.heading" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "General" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Allgemein" } } } },
    "help.settings.s1.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Choose between Light, Dark and System appearance. System follows your macOS setting automatically.\n\nSelect an accent color to personalize the look of Plink across all views." } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Zwischen Hell, Dunkel und System-Darstellung wählen. System folgt automatisch den macOS-Einstellungen.\n\nEine Akzentfarbe auswählen, um das Aussehen von Plink in allen Ansichten zu personalisieren." } } } },
    "help.settings.s2.heading" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Smart Input" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Smarte Eingabe" } } } },
    "help.settings.s2.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Enable or disable Smart Input. See the Smart Input topic for full details. The engine badge shows which AI technology is powering the feature on your Mac." } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Smarte Eingabe aktivieren oder deaktivieren. Alle Details im Thema \"Smarte Eingabe\". Das Engine-Badge zeigt, welche KI-Technologie die Funktion auf dem Mac antreibt." } } } },
    "help.settings.s3.heading" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Shortcut" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Tastenkürzel" } } } },
    "help.settings.s3.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Customize the global Quick Add keyboard shortcut. The default is ⌥Space.\n\nClick the recorder field and press your desired key combination to set a new shortcut. The change takes effect immediately." } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Das globale Schnelleingabe-Tastenkürzel anpassen. Standard ist ⌥Leertaste.\n\nAuf das Aufnahmefeld klicken und die gewünschte Tastenkombination drücken. Die Änderung tritt sofort in Kraft." } } } },
    "help.settings.s3.warning" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Avoid ⌘Space — it is reserved by Spotlight." } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "⌘Leertaste vermeiden — sie ist für Spotlight reserviert." } } } },
    "help.settings.s4.heading" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Advanced — Reset" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Erweitert — Zurücksetzen" } } } },
    "help.settings.s4.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The Reset button permanently deletes all tasks and groups and returns Plink to a clean state. A confirmation dialog shows the exact number of items that will be deleted." } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Der Zurücksetzen-Button löscht alle Aufgaben und Gruppen endgültig und setzt Plink auf den Ausgangszustand zurück. Ein Bestätigungsdialog zeigt die genaue Anzahl der zu löschenden Einträge." } } } },
    "help.settings.s4.warning" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "This action cannot be undone." } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Diese Aktion kann nicht rückgängig gemacht werden." } } } },

    "help.shortcuts.title" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Keyboard Shortcuts" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Tastaturkürzel" } } } },
    "help.shortcuts.s1.heading" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Global" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Global" } } } },
    "help.shortcuts.s1.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "⌥Space — Open / close Quick Add panel (customizable in Settings)" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "⌥Leertaste — Schnelleingabe-Panel öffnen / schließen (anpassbar in den Einstellungen)" } } } },
    "help.shortcuts.s2.heading" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Dashboard" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Übersicht" } } } },
    "help.shortcuts.s2.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "⌥N — New Task (opens the New Task sheet)\n⌘F — Focus search bar" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "⌥N — Neue Aufgabe (öffnet den Neue-Aufgabe-Dialog)\n⌘F — Suchleiste fokussieren" } } } },
    "help.shortcuts.s3.heading" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Quick Add & New Task" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Schnelleingabe & Neue Aufgabe" } } } },
    "help.shortcuts.s3.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Return — Submit / save task\n⌘Return — Submit / save task (alternative)\nEsc — Close without saving" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Return — Aufgabe senden / speichern\n⌘Return — Aufgabe senden / speichern (Alternative)\nEsc — Schließen ohne Speichern" } } } },
    "help.shortcuts.s4.heading" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Task Detail" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Aufgaben-Detail" } } } },
    "help.shortcuts.s4.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Return — Save and close\n⌘Return — Save and close (alternative)\nShift+Return — New line in description field\nEsc — Discard changes and close" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Return — Speichern und schließen\n⌘Return — Speichern und schließen (Alternative)\nShift+Return — Neue Zeile im Beschreibungsfeld\nEsc — Änderungen verwerfen und schließen" } } } },
    "help.shortcuts.s5.heading" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Settings" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "Einstellungen" } } } },
    "help.shortcuts.s5.body" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "⌘, — Open Settings (standard macOS)" } }, "de" : { "stringUnit" : { "state" : "translated", "value" : "⌘, — Einstellungen öffnen (Standard macOS)" } } } }

  },
  "version" : "1.0"
}
