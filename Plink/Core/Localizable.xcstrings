    "onboarding.smart.body" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Smarte Eingabe aktivieren und Plink erkennt automatisch Titel, Datum und Priorität aus natürlicher Sprache.\n\n\"Morgen John anrufen, dringend\" → fällig morgen · hohe Priorität"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enable Smart Input and Plink will automatically extract the title, due date, and priority from natural language.\n\n\"Call John tomorrow, urgent\" → due tomorrow · high priority"
          }
        }
      }
    },
