    "help.smart.s1.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die smarte Eingabe erlaubt dir, Aufgaben mit Tokens zu erfassen — schnell, tippfreundlich und zuverlässig. Tokens beginnen mit einem Symbol (@, @@, #, !) und werden direkt im Eingabefeld geschrieben."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Smart Input lets you capture tasks using tokens — fast, keyboard-friendly and reliable. Tokens start with a symbol (@, @@, #, !) and are typed directly in the input field."
          }
        }
      }
    },
    "help.smart.s1.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Was ist die smarte Eingabe?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What is Smart Input?"
          }
        }
      }
    },
    "help.smart.s2.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unter Einstellungen → Smarte Eingabe den Schalter aktivieren. Ein ✦-Smart-Button erscheint dann in der Schnelleingabe und im Neue-Aufgabe-Dialog."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Go to Settings → Smart Input and turn on the toggle. A ✦ Smart button will appear in the Quick Add panel and the New Task sheet."
          }
        }
      }
    },
    "help.smart.s2.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Smarte Eingabe aktivieren"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enabling Smart Input"
          }
        }
      }
    },
    "help.smart.s3.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "@  Datum — @today · @tomorrow · @monday · @10.05.\n@@ Uhrzeit — @@10:00 · @@14:30\n#  Gruppe — #Peter Park  (Leerzeichen erlaubt)\n!  Flag — !h (high) · !m (medium) · !l (low) · !b (blocked) · !x (blocking)"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "@  Date — @today · @tomorrow · @monday · @10.05.\n@@ Time — @@10:00 · @@14:30\n#  Group — #Peter Park  (spaces allowed)\n!  Flag — !h (high) · !m (medium) · !l (low) · !b (blocked) · !x (blocking)"
          }
        }
      }
    },
    "help.smart.s3.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Token-Syntax"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Token syntax"
          }
        }
      }
    },
    "help.smart.s4.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• Meeting @tomorrow @@10:00 #Arbeit !h\n  → Titel: Meeting · Morgen 10:00 · Gruppe: Arbeit · Hoch\n\n• Zahnarzt @10.05. @@14:30 !m\n  → Titel: Zahnarzt · 10. Mai 14:30 · Mittel\n\n• Bericht abgeben @friday #Privat !x\n  → Titel: Bericht abgeben · Nächsten Freitag · Gruppe: Privat · Ich blockiere"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• Meeting @tomorrow @@10:00 #Work !h\n  → Title: Meeting · Tomorrow 10:00 · Group: Work · High\n\n• Dentist @10.05. @@14:30 !m\n  → Title: Dentist · May 10 14:30 · Medium\n\n• Submit report @friday #Private !x\n  → Title: Submit report · Next Friday · Group: Private · Blocking"
          }
        }
      }
    },
    "help.smart.s4.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beispiele"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Examples"
          }
        }
      }
    },
    "help.smart.s5.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sobald du ein Token-Symbol tippst, erscheinen passende Vorschläge. Mit ↹ Tab übernimmst du den ersten Vorschlag und kannst direkt weitertippen.\n\n• # → zeigt bestehende Gruppen gefiltert nach Eingabe\n• ! → zeigt !h · !m · !l · !b · !x\n• @ → zeigt Datums-Kurzwörter\n• @@ → zeigt Uhrzeiten"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "As soon as you type a token symbol, matching suggestions appear. Press ↹ Tab to accept the top suggestion and keep typing.\n\n• # → shows existing groups filtered by your input\n• ! → shows !h · !m · !l · !b · !x\n• @ → shows date keywords\n• @@ → shows time suggestions"
          }
        }
      }
    },
    "help.smart.s5.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Autocomplete & Tab"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Autocomplete & Tab"
          }
        }
      }
    },
    "help.smart.s5.tip" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Anleitung kann im Eingabefeld mit \"Ausblenden\" versteckt werden. Mit dem ?-Button lässt sie sich jederzeit wieder einblenden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The guide can be hidden in the input panel using \"Hide\". Tap the ? button to show it again at any time."
          }
        }
      }
    },
    "help.smart.s6.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tokens werden stets aus dem Titel entfernt — auch wenn der Wert ungültig ist.\n\n• @32.12. → kein gültiges Datum → Task ohne Datum\n• !xyz → unbekanntes Keyword → ignoriert (keine Prio gesetzt)\n• #Pravit → kein Gruppen-Match → Task ohne Gruppe\n\nKein Fehler-Dialog. Die Eingabe wird immer gespeichert."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tokens are always stripped from the title — even if the value is invalid.\n\n• @32.12. → invalid date → task saved without date\n• !xyz → unknown keyword → ignored (no priority set)\n• #Prvate → no group match → task saved without group\n\nNo error dialogs. The task is always saved."
          }
        }
      }
    },
    "help.smart.s6.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unbekannte Werte & Fehlerbehandlung"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unknown values & error handling"
          }
        }
      }
    },
    "help.smart.s6.tip" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alle Verarbeitung erfolgt lokal auf dem Gerät. Es werden keine Daten an Server gesendet."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "All processing is local and on-device. Nothing is sent to any server."
          }
        }
      }
    },
    "help.smart.title" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Smarte Eingabe"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Smart Input"
          }
        }
      }
    },
    "help.title" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hilfe"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Help"
          }
        }
      }
    },
    "help.trash.s1.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Papierkorb enthält zwei Arten von Einträgen:\n• Gelöschte Aufgaben — manuell gelöscht oder beim Löschen einer Gruppe\n• Erledigte Aufgaben — nach dem 30-Minuten-Sichtbarkeitsfenster hierher verschoben"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trash contains two kinds of items:\n• Deleted tasks — manually deleted from the dashboard or when a group was deleted\n• Completed tasks — moved here after the 30-minute visibility window"
          }
        }
      }
    },
    "help.trash.s1.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Was im Papierkorb erscheint"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What appears in Trash"
          }
        }
      }
    },
    "help.trash.s2.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Über eine Aufgabe im Papierkorb hovern und auf \"Wiederherstellen\" klicken, oder Rechtsklick und \"Wiederherstellen\" wählen. Die Aufgabe kehrt als offene Aufgabe in die Übersicht zurück."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hover over a task in Trash and click Restore, or right-click and choose Restore. The task returns to the dashboard as an open task."
          }
        }
      }
    },
    "help.trash.s2.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aufgabe wiederherstellen"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Restoring a task"
          }
        }
      }
    },
    "help.trash.s3.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Über eine Aufgabe hovern und auf \"Löschen\" klicken, oder den \"Leeren\"-Button neben jedem Abschnitt-Header verwenden, um alle Einträge auf einmal zu entfernen.\n\nDer \"Papierkorb leeren\"-Button in der Symbolleiste löscht alles auf einmal endgültig."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hover over a task and click Delete, or use the Clear button next to each section header to remove all items in that section at once.\n\nThe Empty Trash button in the toolbar permanently deletes everything in one action."
          }
        }
      }
    },
    "help.trash.s3.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Endgültig löschen"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Permanent deletion"
          }
        }
      }
    },
    "help.trash.s3.warning" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Endgültiges Löschen kann nicht rückgängig gemacht werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Permanent deletion cannot be undone."
          }
        }
      }
    },
    "help.trash.s4.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Einträge im Papierkorb werden nach 6 Monaten automatisch und endgültig gelöscht. Es ist keine manuelle Aktion erforderlich."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Items in Trash are automatically and permanently deleted after 6 months. There is no manual action required."
          }
        }
      }
    },
    "help.trash.s4.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Automatische Bereinigung"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Automatic cleanup"
          }
        }
      }
    },
    "help.trash.title" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Papierkorb"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trash"
          }
        }
      }
    },
