          }
        }
      }
    },
    "onboarding.quickadd.body" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⌥Leertaste aus jeder App drücken, um das Schnelleingabe-Panel zu öffnen. Aufgabe eintippen und Return drücken. Fertig.\n\nDas Tastenkürzel kann jederzeit in den Einstellungen angepasst werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Press ⌥Space from any app to open the Quick Add panel. Type your task and hit Return. Done.\n\nYou can customize the shortcut any time in Settings."
          }
        }
      }
    },
    "onboarding.quickadd.subtitle" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alles in unter einer Sekunde erfassen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Capture anything in under a second."
          }
        }
      }
    },
    "onboarding.quickadd.title" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schnelleingabe"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quick Add"
          }
        }
      }
    },
    "onboarding.recurring.body" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Setze ein Fälligkeitsdatum für eine Aufgabe und wähle dann eine Wiederholung — täglich, wöchentlich, monatlich oder jährlich. Wenn du die Aufgabe abhakst, erstellt Klen automatisch den nächsten Termin."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Set a due date on any task and choose a recurrence — daily, weekly, monthly or yearly. When you check it off, Klen automatically creates the next occurrence for you."
          }
        }
      }
    },
    "onboarding.recurring.subtitle" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vergiss nie wieder eine regelmäßige Aufgabe."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Never miss a regular task again."
          }
        }
      }
    },
    "onboarding.recurring.title" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wiederkehrende Aufgaben"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recurring Tasks"
          }
        }
      }
    },
    "onboarding.smart.body" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Smarte Eingabe aktivieren und Klen erkennt automatisch Titel, Datum und Priorität aus natürlicher Sprache.\n\n\"Morgen John anrufen, dringend\" → fällig morgen · hohe Priorität"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enable Smart Input and Klen will automatically extract the title, due date, and priority from natural language.\n\n\"Call John tomorrow, urgent\" → due tomorrow · high priority"
          }
        }
      }
    },
    "onboarding.smart.subtitle" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Einfach beschreiben, was zu tun ist."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Just describe what you need to do."
          }
        }
      }
    },
