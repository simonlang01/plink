          "stringUnit" : {
            "state" : "translated",
            "value" : " und %d Aufgabe(n)"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " and %d task(s)"
          }
        }
      }
    },
    "group.delete.confirm.title" : {
