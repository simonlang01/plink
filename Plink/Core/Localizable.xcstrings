      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⌃F (Standard) — Fokusmodus ein-/ausschalten. Das Kürzel kann in den Einstellungen unter \"Tastaturkürzel\" geändert werden."
          }
