          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Smart Input"
          }
        }
      }
    },
    "onboarding.welcome.body" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Klen lebt in deiner Menüleiste und ist immer nur einen Tastendruck entfernt – egal welche App du gerade verwendest."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
