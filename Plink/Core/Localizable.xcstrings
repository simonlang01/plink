    "help.activitylog.s1.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Aktivitätslog zeigt alle Aktionen der letzten 30 Tage: erstellte, abgeschlossene und gelöschte Aufgaben — nach Tag gruppiert und mit genauer Uhrzeit."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The Activity Log shows everything you've done in the last 30 days: tasks created, completed, and deleted — grouped by day with exact timestamps."
          }
        }
      }
    },
    "help.activitylog.s1.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Was wird angezeigt"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What's tracked"
          }
        }
      }
    },
    "help.activitylog.s2.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jeder Eintrag zeigt:\n• Aufgabentitel\n• Art des Ereignisses (Erstellt / Abgeschlossen / Gelöscht)\n• Gruppe (falls zugewiesen)\n• Genaue Uhrzeit\n\nErstellte Aufgaben erscheinen in Grau, abgeschlossene in Grün, gelöschte durchgestrichen in Rot."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Each entry shows:\n• Task title\n• Event type (Created / Completed / Deleted)\n• Group (if assigned)\n• Exact time\n\nCreated events appear in grey, completed in green, deleted in red with strikethrough."
          }
        }
      }
    },
    "help.activitylog.s2.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eintragsformat"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Entry format"
          }
        }
      }
    },
    "help.activitylog.s3.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Log zeigt Ereignisse der letzten 30 Tage. Ältere Ereignisse werden automatisch aus dem Log entfernt, sobald die 6-monatige Aufbewahrungsfrist für Aufgaben abläuft."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The log shows events from the last 30 days. Older events are automatically removed when tasks are purged after the 6-month retention period."
          }
        }
      }
    },
    "help.activitylog.s3.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aufbewahrung"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Retention"
          }
        }
      }
    },
    "help.activitylog.s3.tip" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Den Aktivitätslog über die Seitenleiste öffnen — er befindet sich zwischen dem Papierkorb und den Einstellungen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Open the Activity Log from the sidebar — it sits between Trash and Settings."
          }
        }
      }
    },
    "help.activitylog.title" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aktivitätslog"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Activity Log"
          }
        }
      }
    },
    "help.backup.s1.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gehe zu Einstellungen → Erweitert und tippe auf „Backup exportieren“. Plink speichert alle Aufgaben, Gruppen und Anhänge in einer einzigen .plinkbackup-Datei. Speichere sie beliebig — auf dem Schreibtisch, einem USB-Stick oder im iCloud-Drive-Ordner für automatische Cloud-Sicherung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Go to Settings → Advanced and tap “Export Backup”. Plink saves all your tasks, groups and attachments into a single .plinkbackup file. Save it anywhere — your Desktop, a USB drive, or your iCloud Drive folder for automatic cloud backup."
          }
        }
      }
    },
    "help.backup.s1.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Backup exportieren"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Export a Backup"
          }
        }
      }
    },
    "help.backup.s2.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gehe zu Einstellungen → Erweitert und tippe auf „Backup importieren“. Wähle deine .plinkbackup-Datei aus. Nach der Bestätigung wird der gesamte aktuelle Datenbestand durch das Backup ersetzt. Dies kann nicht rückgängig gemacht werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Go to Settings → Advanced and tap “Import Backup”. Select your .plinkbackup file. After confirming, all current data will be replaced with the backup contents. This cannot be undone."
          }
        }
      }
    },
    "help.backup.s2.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Backup importieren"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Import a Backup"
          }
        }
      }
    },
    "help.backup.s2.tip" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Backup-Datei enthält alles – Aufgaben, Gruppen, Anhänge und alle Metadaten. Du kannst sie nutzen, um deine Daten auf einen neuen Mac zu übertragen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The backup file contains everything — tasks, groups, attachments and all metadata. You can use it to move your data to a new Mac."
          }
        }
      }
    },
    "help.backup.s3.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Speichere die .plinkbackup-Datei in iCloud Drive, um sie automatisch auf allen deinen Macs zu synchronisieren. Kein zusätzlicher Aufwand – einfach iCloud Drive im Speichern-Dialog auswählen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Save your .plinkbackup file to iCloud Drive to automatically sync it across all your Macs. No extra setup required — just choose iCloud Drive in the save dialog."
          }
        }
      }
    },
    "help.backup.s3.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCloud-Drive-Tipp"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCloud Drive Tip"
          }
        }
      }
    },
    "help.backup.title" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sichern & Wiederherstellen"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Backup & Restore"
          }
        }
      }
    },
    "help.dashboard.s1.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Übersicht zeigt alle offenen Aufgaben in Abschnitten: Überfällig, Heute, Morgen, Nächste 7 Tage, Später, Kein Datum und Kürzlich erledigt.\n\nÜberfällige Aufgaben sind rot hervorgehoben. Kürzlich erledigte Aufgaben verschwinden nach 30 Minuten aus der Übersicht."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The dashboard shows all your open tasks organised into sections: Overdue, Today, Tomorrow, Next 7 Days, Later, No Date, and Recently Completed.\n\nOverdue tasks are highlighted in red. Recently Completed tasks disappear after 30 minutes."
          }
        }
      }
    },
    "help.dashboard.s1.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Übersicht"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Overview"
          }
        }
      }
    },
    "help.dashboard.s2.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Über eine Aufgabenzeile hovern — rechts erscheint ein türkiser ✓-Button. Klicken, um die Aufgabe als erledigt zu markieren. Alternativ Rechtsklick und \"Als erledigt markieren\" wählen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hover over any task row — a teal ✓ button appears on the right. Click it to mark the task as complete. You can also right-click a row and choose Mark Complete."
          }
        }
      }
    },
    "help.dashboard.s2.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aufgabe erledigen"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Completing a task"
          }
        }
      }
    },
    "help.dashboard.s2.tip" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erledigte Aufgaben bleiben 30 Minuten sichtbar, damit versehentliche Aktionen rückgängig gemacht werden können."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Completed tasks stay visible for 30 minutes so you can undo by mistake."
          }
        }
      }
    },
    "help.dashboard.s3.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Auf eine Aufgabenzeile klicken (nicht auf den Erledigt-Button), um das Detailfeld zu öffnen. Dort können Titel, Beschreibung, Datum, Priorität und Gruppe bearbeitet werden.\n\nÄnderungen werden beim Schließen automatisch gespeichert. Esc oder × drücken, um zu verwerfen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Click anywhere on a task row (except the complete button) to open the detail panel. Here you can edit the title, description, due date, priority and group.\n\nChanges are saved automatically when you close the panel. Press Esc or click the × button to discard."
          }
        }
      }
    },
    "help.dashboard.s3.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aufgabe bearbeiten"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Editing a task"
          }
        }
      }
    },
    "help.dashboard.s4.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rechtsklick auf eine Aufgabenzeile und \"Löschen\" wählen. Die Aufgabe wird in den Papierkorb verschoben und kann innerhalb von 6 Monaten wiederhergestellt werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Right-click a task row and choose Delete. The task moves to Trash and can be restored within 6 months."
          }
        }
      }
    },
    "help.dashboard.s4.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aufgabe löschen"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deleting a task"
          }
        }
      }
    },
    "help.dashboard.s5.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oberhalb der Aufgabenliste zeigt eine kompakte Leiste fünf Live-Zahlen: Offen, Heute fällig, Überfällig, Diese Woche erledigt und Diese Woche erstellt. Die Zahlen aktualisieren sich automatisch."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A compact bar above the task list shows five live numbers: Open, Due today, Overdue, Done this week, and Created this week. The numbers update automatically."
          }
        }
      }
    },
    "help.dashboard.s5.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Statistik-Leiste"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stats bar"
          }
        }
      }
    },
    "help.dashboard.s5.tip" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Überfällig\" wird rot, sobald mindestens eine Aufgabe überfällig ist. \"Diese Woche erledigt\" wird grün, sobald du etwas abgehakt hast."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Overdue\" turns red as soon as any task is overdue. \"Done this week\" turns green once you've checked something off."
          }
        }
      }
    },
    "help.dashboard.title" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Übersicht"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dashboard"
          }
        }
      }
    },
    "help.groups.s1.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "In der Seitenleiste auf + Neue Gruppe klicken, einen Namen eingeben und Return drücken. Gruppen erscheinen in der Seitenleiste unterhalb von \"Nicht zugeordnet\"."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Click + New Group in the sidebar and type a name, then press Return. Groups appear in the sidebar below Unassigned."
          }
        }
      }
    },
    "help.groups.s1.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gruppe erstellen"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Creating a group"
          }
        }
      }
    },
    "help.groups.s2.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Nicht zugeordnet\" ist eine permanente, eingebaute Gruppe, die automatisch alle Aufgaben ohne Gruppe sammelt. Sie kann nicht gelöscht werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unassigned is a permanent, built-in group that automatically collects all tasks without a group. It cannot be deleted."
          }
        }
      }
    },
    "help.groups.s2.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nicht zugeordnet"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unassigned"
          }
        }
      }
    },
    "help.groups.s3.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jede Gruppe zeigt zwei Badges:\n• Ein neutrales Badge — Gesamtzahl offener Aufgaben\n• Ein rotes Badge — überfällige Aufgaben (ersetzt das neutrale Badge, wenn vorhanden)"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Each group shows two badges:\n• A neutral badge — total open tasks\n• A red badge — overdue tasks (replaces the neutral badge when present)"
          }
        }
      }
    },
    "help.groups.s3.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aufgabenzähler"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Task counts"
          }
        }
      }
    },
    "help.groups.s4.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rechtsklick auf eine Gruppe in der Seitenleiste und \"Löschen\" wählen. Ein Bestätigungsdialog bietet zwei Optionen:"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Right-click a group in the sidebar and choose Delete. A confirmation dialog gives you two options:"
          }
        }
      }
    },
    "help.groups.s4.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gruppe löschen"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deleting a group"
          }
        }
      }
    },
    "help.groups.s4.tip" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Gruppe und alle Aufgaben löschen\" → Aufgaben werden in den Papierkorb verschoben.\n\"Gruppe löschen, Aufgaben behalten\" → Aufgaben werden nach \"Nicht zugeordnet\" verschoben."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Delete Group and All Tasks\" → tasks move to Trash.\n\"Delete Group, Keep Tasks\" → tasks move to Unassigned."
          }
        }
      }
    },
    "help.groups.s5.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Auf eine Gruppe in der Seitenleiste klicken, um die Übersicht auf die Aufgaben dieser Gruppe zu filtern. Auf \"Alle Aufgaben\" klicken, um zur vollständigen Ansicht zurückzukehren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Click any group in the sidebar to filter the dashboard to only that group's tasks. Click All Tasks to return to the full view."
          }
        }
      }
    },
    "help.groups.s5.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nach Gruppe filtern"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Filtering by group"
          }
        }
      }
    },
    "help.groups.s6.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rechtsklick auf eine Gruppe in der Seitenleiste und \"Umbenennen\" wählen. Der Gruppenname wird zu einem Textfeld — neuen Namen eingeben und Return drücken, um zu speichern, oder Esc zum Abbrechen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Right-click any group in the sidebar and choose Rename. The group name turns into an inline text field — type the new name and press Return to save, or press Esc to cancel."
          }
        }
      }
    },
    "help.groups.s6.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gruppe umbenennen"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Renaming a group"
          }
        }
      }
    },
    "help.groups.title" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gruppen"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Groups"
          }
        }
      }
    },
    "help.notif.s1.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn eine Aufgabe ein Fälligkeitsdatum und eine Uhrzeit hat, sendet Plink 15 Minuten vor der Deadline eine lokale Benachrichtigung. Kein Account oder Internet erforderlich — alles läuft lokal."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When a task has a due date and a due time set, Plink schedules a local notification that fires 15 minutes before the deadline. No account or internet connection is required — everything runs on-device."
          }
        }
      }
    },
    "help.notif.s1.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "So funktioniert es"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "How it works"
          }
        }
      }
    },
    "help.notif.s2.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Im \"Neue Aufgabe\"-Fenster oder in der Aufgaben-Detailansicht zuerst ein Fälligkeitsdatum aktivieren (Heute, Morgen oder benutzerdefiniert). Anschließend erscheint ein Uhrzeit-Chip — antippen, um eine Zeit zu aktivieren und mit dem Stepper anzupassen. Eine Benachrichtigung wird nur geplant, wenn sowohl Datum als auch Uhrzeit gesetzt sind."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "In the Add Task sheet or Task Detail view, first enable a due date (Today, Tomorrow, or a custom date). A clock chip then appears — tap it to activate a time and adjust it with the stepper. A notification is only scheduled when both a date and a time are set."
          }
        }
      }
    },
    "help.notif.s2.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uhrzeit festlegen"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Setting a due time"
          }
        }
      }
    },
    "help.notif.s2.tip" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Aufgabenzeile im Dashboard zeigt sowohl Datum als auch Uhrzeit, wenn eine Zeit gesetzt ist, z. B. \"4. Apr · 15:25\"."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The task row in the dashboard shows both the date and the time when a due time is set, e.g. \"4 Apr · 15:25\"."
          }
        }
      }
    },
    "help.notif.s3.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jede Erinnerung hat drei Schnellaktionen:\n• Erledigt — markiert die Aufgabe sofort als erledigt.\n• 30 Min. später — sendet eine weitere Erinnerung 30 Minuten später, ohne das Fälligkeitsdatum zu ändern.\n• Auf morgen verschieben — verschiebt das Datum auf den nächsten Tag und plant die Erinnerung neu."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Each reminder has three quick actions:\n• Done — marks the task as completed immediately.\n• Snooze 30 min — fires another reminder 30 minutes later without changing the due date.\n• Tomorrow — moves the due date to the next day and reschedules the reminder."
          }
        }
      }
    },
    "help.notif.s3.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aktionen in der Benachrichtigung"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Notification actions"
          }
        }
      }
    },
    "help.notif.s4.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unter Einstellungen → Benachrichtigungen kannst du:\n• Alle Benachrichtigungen mit dem Hauptschalter ein- oder ausschalten.\n• Alle Hinweise vorübergehend stummschalten (30 Min., 1 Std., 2 Std. oder bis heute Abend) — nützlich in Meetings.\n• Benachrichtigungen pro Gruppe aktivieren oder deaktivieren, z. B. Business an, Privat aus."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "In Settings → Notifications you can:\n• Turn all notifications on or off with the master switch.\n• Mute all alerts temporarily (30 min, 1 h, 2 h, or until tonight) — useful during meetings.\n• Enable or disable notifications per group, e.g. Business on, Private off."
          }
        }
      }
    },
    "help.notif.s4.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Benachrichtigungs-Einstellungen"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Notification settings"
          }
        }
      }
    },
    "help.notif.s4.tip" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Damit Erinnerungen sichtbar bleiben, bis du reagierst, öffne Systemeinstellungen → Mitteilungen → Plink und stelle den Hinweisstil auf \"Dauerhaft\" (nicht \"Vorübergehend\")."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "For reminders to stay on screen until you act on them, open System Settings → Notifications → Plink and set the alert style to \"Alerts\" (not \"Banners\")."
          }
        }
      }
    },
    "help.notif.title" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Benachrichtigungen"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Notifications"
          }
        }
      }
    },
    "help.quickadd.s1.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⌥Leertaste (Option + Leertaste) aus jeder App drücken — auch wenn Plink im Hintergrund ist — um das Schnelleingabe-Panel zu öffnen. Plink übernimmt niemals den Fokus vom aktuellen Fenster."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Press ⌥Space (Option + Space) from any app — even when Plink is in the background — to open the Quick Add panel. Plink never steals focus from your current window."
          }
        }
      }
    },
    "help.quickadd.s1.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Globales Tastenkürzel"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Global shortcut"
          }
        }
      }
    },
    "help.quickadd.s1.tip" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dieses Kürzel kann unter Einstellungen → Tastenkürzel geändert werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You can change this shortcut in Settings → Shortcut."
          }
        }
      }
    },
    "help.quickadd.s2.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aufgabentitel eingeben und Return drücken oder den →-Button klicken. Das Panel schließt sich nach dem Hinzufügen automatisch."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Type your task title and press Return or click the → button. The panel closes automatically after adding."
          }
        }
      }
    },
    "help.quickadd.s2.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aufgabe hinzufügen"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Adding a task"
          }
        }
      }
    },
    "help.quickadd.s3.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Chips \"Heute\" und \"Morgen\" für schnelle Datumszuweisung verwenden. Auf den Kalender-Chip klicken, um ein beliebiges Datum zu wählen.\n\nSobald ein Datum gesetzt ist, erscheint ein Uhr-Chip — antippen, um eine genaue Uhrzeit hinzuzufügen. Einen aktiven Chip erneut antippen, um die Auswahl zu löschen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Use the Today and Tomorrow chips for quick date assignment. Click the calendar chip to pick any date.\n\nOnce a date is set, a clock chip appears — tap it to add an exact time. Tap an active chip again to clear it."
          }
        }
      }
    },
    "help.quickadd.s3.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fälligkeitsdatum"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Due date"
          }
        }
      }
    },
    "help.quickadd.s4.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Auf das 🚩-Flag-Menü klicken, um eine Priorität zu setzen: Niedrig, Mittel oder Hoch. Die Priorität wird als farbiger Punkt in der Aufgabenzeile angezeigt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Click the 🚩 flag menu to set a priority: Low, Medium or High. Priority is shown as a coloured dot on the task row."
          }
        }
      }
    },
    "help.quickadd.s4.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Priorität"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Priority"
          }
        }
      }
    },
    "help.quickadd.s5.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn Gruppen erstellt wurden, erscheint ein Ordner-Menü. Eine Gruppe auswählen, um die Aufgabe zuzuweisen, oder nicht zugeordnet lassen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If you have created groups, a folder menu appears. Select a group to assign the task to it, or leave it unassigned."
          }
        }
      }
    },
    "help.quickadd.s5.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gruppe"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Group"
          }
        }
      }
    },
    "help.quickadd.s6.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esc drücken, Return in einem leeren Feld drücken oder außerhalb des Panels klicken, um es zu schließen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Press Esc, press Return on an empty field, or click anywhere outside the panel to close it."
          }
        }
      }
    },
    "help.quickadd.s6.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Panel schließen"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Closing the panel"
          }
        }
      }
    },
    "help.quickadd.title" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schnelleingabe"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quick Add"
          }
        }
      }
    },
    "help.search.s1.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "In der Symbolleiste auf die Suchleiste klicken (oder ⌘F drücken) und zu tippen beginnen. Plink durchsucht sowohl Titel als auch Beschreibung jeder Aufgabe."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Click the search bar in the toolbar (or press ⌘F) and start typing. Plink searches both the title and description of every task."
          }
        }
      }
    },
    "help.search.s1.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aufgaben finden"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finding tasks"
          }
        }
      }
    },
    "help.search.s2.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn eine Suche aktiv ist, werden auch erledigte Aufgaben in den Ergebnissen unter einem \"Erledigt\"-Abschnitt angezeigt — nicht nur kürzlich erledigte."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When a search query is active, completed tasks are also included in the results under a Completed section — not just recently completed ones."
          }
        }
      }
    },
    "help.search.s2.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erledigte Aufgaben"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Completed tasks"
          }
        }
      }
    },
    "help.search.s2.tip" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "So können alle jemals hinzugefügten Aufgaben gefunden werden, auch wenn sie vor Monaten erledigt wurden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This lets you find any task you have ever added, even if it was completed months ago."
          }
        }
      }
    },
    "help.search.s3.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Suche berücksichtigt den aktuellen Gruppenfilter. Zuerst eine Gruppe auswählen und dann suchen, um nur Aufgaben dieser Gruppe zu finden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Search respects the current group filter. Select a group first and then search to find tasks only within that group."
          }
        }
      }
    },
    "help.search.s3.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mit Gruppen kombinieren"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Combining with groups"
          }
        }
      }
    },
    "help.search.title" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Suche"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Search"
          }
        }
      }
    },
    "help.settings.s1.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zwischen Hell, Dunkel und System-Darstellung wählen. System folgt automatisch den macOS-Einstellungen.\n\nEine Akzentfarbe auswählen, um das Aussehen von Plink in allen Ansichten zu personalisieren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choose between Light, Dark and System appearance. System follows your macOS setting automatically.\n\nSelect an accent color to personalize the look of Plink across all views."
          }
        }
      }
    },
    "help.settings.s1.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Allgemein"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "General"
          }
        }
      }
    },
    "help.settings.s2.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Smart-Eingabe aktivieren oder deaktivieren und die aktive Engine konfigurieren. Weitere Details im Thema Smart-Eingabe."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enable or disable Smart Input and configure the active engine. See the Smart Input topic for full details."
          }
        }
      }
    },
    "help.settings.s2.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Smarte Eingabe"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Smart Input"
          }
        }
      }
    },
    "help.settings.s3.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das globale Schnelleingabe-Tastenkürzel anpassen. Standard ist ⌥Leertaste.\n\nAuf das Aufnahmefeld klicken und die gewünschte Tastenkombination drücken. Die Änderung tritt sofort in Kraft."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Customize the global Quick Add keyboard shortcut. The default is ⌥Space.\n\nClick the recorder field and press your desired key combination to set a new shortcut. The change takes effect immediately."
          }
        }
      }
    },
    "help.settings.s3.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tastenkürzel"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Shortcut"
          }
        }
      }
    },
    "help.settings.s3.warning" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⌘Leertaste vermeiden — sie ist für Spotlight reserviert."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Avoid ⌘Space — it is reserved by Spotlight."
          }
        }
      }
    },
    "help.settings.s4.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Zurücksetzen-Button löscht alle Aufgaben und Gruppen endgültig und setzt Plink auf den Ausgangszustand zurück. Ein Bestätigungsdialog zeigt die genaue Anzahl der zu löschenden Einträge."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The Reset button permanently deletes all tasks and groups and returns Plink to a clean state. A confirmation dialog shows the exact number of items that will be deleted."
          }
        }
      }
    },
    "help.settings.s4.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erweitert — Zurücksetzen"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Advanced — Reset"
          }
        }
      }
    },
    "help.settings.s4.warning" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diese Aktion kann nicht rückgängig gemacht werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This action cannot be undone."
          }
        }
      }
    },
    "help.settings.title" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Einstellungen"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Settings"
          }
        }
      }
    },
    "help.shortcuts.s1.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⌥Leertaste — Schnelleingabe-Panel öffnen / schließen (anpassbar in den Einstellungen)"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⌥Space — Open / close Quick Add panel (customizable in Settings)"
          }
        }
      }
    },
    "help.shortcuts.s1.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Global"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Global"
          }
        }
      }
    },
    "help.shortcuts.s2.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⌥N — Neue Aufgabe (öffnet den Neue-Aufgabe-Dialog)\n⌘F — Suchleiste fokussieren"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⌥N — New Task (opens the New Task sheet)\n⌘F — Focus search bar"
          }
        }
      }
    },
    "help.shortcuts.s2.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Übersicht"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dashboard"
          }
        }
      }
    },
    "help.shortcuts.s3.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Return — Aufgabe senden / speichern\n⌘Return — Aufgabe senden / speichern (Alternative)\nEsc — Schließen ohne Speichern"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Return — Submit / save task\n⌘Return — Submit / save task (alternative)\nEsc — Close without saving"
          }
        }
      }
    },
    "help.shortcuts.s3.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schnelleingabe & Neue Aufgabe"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quick Add & New Task"
          }
        }
      }
    },
    "help.shortcuts.s4.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Return — Speichern und schließen\n⌘Return — Speichern und schließen (Alternative)\nShift+Return — Neue Zeile im Beschreibungsfeld\nEsc — Änderungen verwerfen und schließen"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Return — Save and close\n⌘Return — Save and close (alternative)\nShift+Return — New line in description field\nEsc — Discard changes and close"
          }
        }
      }
    },
